# Among Us Bot — Environment Variables (.env)
# Kopiere diese Datei zu .env und fülle die Werte aus

# ═══════════════════════════════════════════════════════════
#  DISCORD BOT TOKEN (für Admin-Commands)
# ═══════════════════════════════════════════════════════════
DISCORD_TOKEN=your_bot_token_here

# ═══════════════════════════════════════════════════════════
#  DISCORD OAUTH2 CREDENTIALS
# ═══════════════════════════════════════════════════════════
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_GUILD_ID=your_guild_id_here

# ─ Redirect URI (anpassen an deine Railway-Domain)
# Format: https://your-app.up.railway.app/auth/callback
DISCORD_REDIRECT_URI=https://yourapp.up.railway.app/auth/callback

# ═══════════════════════════════════════════════════════════
#  SICHERHEIT & TOKENS
# ═══════════════════════════════════════════════════════════
ADMIN_TOKEN=generate_a_secure_token_here
INVITE_CODE=your_secret_invite_code

# ─ Optional: Session Secret (wird automatisch generiert wenn leer)
SECRET_KEY=

# ═══════════════════════════════════════════════════════════
#  DATENBANK / PERSISTENZ
# ═══════════════════════════════════════════════════════════
# Standard: JSON-Dateien im Verzeichnis
# Für Railway: Verwende optional PostgreSQL für größere Datenmengen
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# ═══════════════════════════════════════════════════════════
#  SERVER PORTS (lokal)
# ═══════════════════════════════════════════════════════════
PORT=5000
ADMIN_PORT=5001
ADMIN_HOST=0.0.0.0
HOST=0.0.0.0

# ═══════════════════════════════════════════════════════════
#  ERWEITERTE KONFIGURATION
# ═══════════════════════════════════════════════════════════
# DEBUG=False
# TIMEZONE=Europe/Berlin
